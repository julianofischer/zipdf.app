{
  "name": "zipdf-app",
  "version": "0.1.0",
  "private": true,
  "description": "PDF compression that runs 100% locally in the browser.",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
